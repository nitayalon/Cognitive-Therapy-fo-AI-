{
  "experiment_name": "generalization_matrix",
  "description": "Full generalization matrix: Train on single game+opponent range, test across games and opponent ranges",
  
  "games": [
    "prisoners-dilemma",
    "hawk-dove", 
    "stag-hunt"
  ],
  
  "opponent_ranges": {
    "very_low": [0.0, 0.2],
    "low": [0.2, 0.4],
    "mid": [0.4, 0.6],
    "high": [0.6, 0.8],
    "very_high": [0.8, 1.0]
  },
  
  "training_conditions": [
    {"id": 0,  "game": "prisoners-dilemma", "opponent_range": "very_low",  "opponents": [0.0, 0.2]},
    {"id": 1,  "game": "prisoners-dilemma", "opponent_range": "low",       "opponents": [0.2, 0.4]},
    {"id": 2,  "game": "prisoners-dilemma", "opponent_range": "mid",       "opponents": [0.4, 0.6]},
    {"id": 3,  "game": "prisoners-dilemma", "opponent_range": "high",      "opponents": [0.6, 0.8]},
    {"id": 4,  "game": "prisoners-dilemma", "opponent_range": "very_high", "opponents": [0.8, 1.0]},
    {"id": 5,  "game": "hawk-dove",         "opponent_range": "very_low",  "opponents": [0.0, 0.2]},
    {"id": 6,  "game": "hawk-dove",         "opponent_range": "low",       "opponents": [0.2, 0.4]},
    {"id": 7,  "game": "hawk-dove",         "opponent_range": "mid",       "opponents": [0.4, 0.6]},
    {"id": 8,  "game": "hawk-dove",         "opponent_range": "high",      "opponents": [0.6, 0.8]},
    {"id": 9,  "game": "hawk-dove",         "opponent_range": "very_high", "opponents": [0.8, 1.0]},
    {"id": 10, "game": "stag-hunt",         "opponent_range": "very_low",  "opponents": [0.0, 0.2]},
    {"id": 11, "game": "stag-hunt",         "opponent_range": "low",       "opponents": [0.2, 0.4]},
    {"id": 12, "game": "stag-hunt",         "opponent_range": "mid",       "opponents": [0.4, 0.6]},
    {"id": 13, "game": "stag-hunt",         "opponent_range": "high",      "opponents": [0.6, 0.8]},
    {"id": 14, "game": "stag-hunt",         "opponent_range": "very_high", "opponents": [0.8, 1.0]}
  ],
  
  "test_conditions": {
    "same_game_same_opponents": "Baseline in-distribution test",
    "same_game_new_opponents": "Test generalization to new opponent types within same game",
    "new_game_same_opponents": "Test generalization to new game with familiar opponents",
    "new_game_new_opponents": "Test generalization to both new game and new opponents"
  },
  
  "network_config": {
    "hidden_size": 128,
    "num_layers": 2,
    "dropout": 0.1
  },
  
  "training_config": {
    "num_games_per_partner": 100,
    "learning_rate": 0.001,
    "batch_size": 32,
    "max_epochs": 1000,
    "convergence_threshold": 1e-6,
    "patience": 50,
    "checkpoint_frequency": 100
  },
  
  "evaluation_config": {
    "num_sessions": 20,
    "enable_detailed_testing": true
  },
  
  "slurm_config": {
    "total_tasks": 15,
    "task_id_range": "0-14",
    "estimated_time_per_task": "2:00:00",
    "memory_per_task": "8G"
  }
}
